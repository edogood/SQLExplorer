# Common
JWT_SECRET=change-me
PORT=4000

# API execution mode
# local  = execute on local docker sandboxes
# remote = forward execution to remote worker via signed webhook
# no-exec = disable real execution (prod-safe mode for Vercel/GitHub Pages)
EXECUTION_MODE=local

# Local sandbox DSNs
PG_SANDBOX_URL=postgres://postgres:postgres@localhost:5433/sandbox
MYSQL_SANDBOX_URL=mysql://root:root@localhost:3307/sandbox

# Optional remote sandbox settings (used when EXECUTION_MODE=remote)
REMOTE_SANDBOX_EXECUTE_URL=
REMOTE_SANDBOX_HMAC_SECRET=

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_BASE_PATH=
